{
  "manifest_version": 3,
  "name": "Sunny's Dreamjourney Toolkit V2",
  "version": "2.1",
  "description": "Quality-of-life tools for DreamJourney AI chat sessions. Local-only. Made by SunflowerS.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.dreamjourneyai.com/*",
    "https://dreamjourneyai.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.dreamjourneyai.com/*",
        "https://dreamjourneyai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "toolkit.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sunny's Dreamjourney Toolkit V2",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "help.html",
        "help.js",
        "lorebook-studio.html",
        "lorebook-studio.js",
        "creator-tools-help.html",
        "dj-bridge.js",
        "icons/icon16.png",
        "icons/icon32.png",
        "icons/icon48.png",
        "icons/icon128.png",
        "icons/sun64.png",
        "icons/chibi140.png",
        "icons/bg-light.jpg",
        "icons/bg-dark.jpg"
      ],
      "matches": [
        "https://www.dreamjourneyai.com/*",
        "https://dreamjourneyai.com/*"
      ]
    }
  ]
}